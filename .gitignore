# =============================================================================
# Tauri + React + TypeScript + Vite — Root .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
dist-ssr/
build/

# Tauri compilation output (Rust side lives in src-tauri/.gitignore)
src-tauri/target/

# -----------------------------------------------------------------------------
# Vite
# -----------------------------------------------------------------------------
*.local
.vite/

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Environment / secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
# VS Code — keep shared settings, ignore personal/generated ones
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# JetBrains (IntelliJ, WebStorm, CLion, …)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*.sw?
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln
*.user

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.pem
.cache/
